<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="true"/>

    <!-- Classic Bluetooth — restricted to API < 31 (replaced by BLUETOOTH_CONNECT on 31+) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30"/>
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30"/>

    <!-- Android 12+ (API 31+) Bluetooth permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Storage: scoped storage applies from API 29+; this permission only effective on API 28- -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>

    <!-- Location required for BLE scanning on API 23-30; BLUETOOTH_SCAN with neverForLocation covers 31+ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="28"/>

    <application
        android:allowBackup="true"
        android:fullBackupContent="true"
        android:icon="@mipmap/ic_puzzlebox"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <service
            android:name=".service.NeuroSkyThinkGearService"
            android:enabled="true"
            android:exported="false"/>

        <service
            android:name=".service.EmotivInsightService"
            android:enabled="true"
            android:exported="false"/>

        <!--<service-->
            <!--android:name=".service.InteraXonMuseService"-->
            <!--android:enabled="true"-->
            <!--android:exported="false"/>-->

        <!-- <service -->
        <!-- android:name=".service.RedBearLabsService" -->
        <!-- android:enabled="true"/> -->

        <service
            android:name=".service.PuzzleboxGimmickBluetoothService"
            android:enabled="true"
            android:exported="false"/>

    </application>

</manifest>
